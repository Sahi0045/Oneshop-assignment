// =============================================================================
// Prisma Schema — Freelancer Platform
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  CLIENT
  FREELANCER
  ADMIN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum ProjectType {
  FIXED_PRICE
  HOURLY
  CONTEST
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
  DISPUTED
}

enum TransactionType {
  PAYMENT
  REFUND
  WITHDRAWAL
  DEPOSIT
  ESCROW_HOLD
  ESCROW_RELEASE
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum ReviewType {
  CLIENT_TO_FREELANCER
  FREELANCER_TO_CLIENT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BadgeType {
  TOP_RATED
  RISING_TALENT
  VERIFIED
  EXPERT
  RELIABLE
  FAST_RESPONDER
  QUALITY_WORK
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
  ESCALATED
}

enum DisputeReason {
  WORK_NOT_DELIVERED
  WORK_NOT_AS_DESCRIBED
  PAYMENT_NOT_RELEASED
  SCOPE_CREEP
  COMMUNICATION_BREAKDOWN
  DEADLINE_MISSED
  QUALITY_ISSUES
  FRAUD
  OTHER
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ConversationType {
  DIRECT
  PROJECT
  SUPPORT
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  BID_REJECTED
  BID_WITHDRAWN
  CONTRACT_STARTED
  CONTRACT_COMPLETED
  CONTRACT_CANCELLED
  CONTRACT_PAUSED
  MILESTONE_CREATED
  MILESTONE_SUBMITTED
  MILESTONE_APPROVED
  MILESTONE_REVISION_REQUESTED
  MILESTONE_DISPUTED
  PAYMENT_RECEIVED
  PAYMENT_SENT
  PAYMENT_FAILED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_FAILED
  ESCROW_FUNDED
  ESCROW_RELEASED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  DISPUTE_ESCALATED
  DISPUTE_CLOSED
  REVIEW_RECEIVED
  REVIEW_REMINDER
  MESSAGE_RECEIVED
  ACCOUNT_VERIFIED
  ACCOUNT_SUSPENDED
  PROFILE_INCOMPLETE
  PROJECT_EXPIRING
  PROJECT_CLOSED
  SYSTEM
}

// =============================================================================
// MODELS
// =============================================================================

// -----------------------------------------------------------------------------
// User
// -----------------------------------------------------------------------------

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?
  googleId           String?   @unique
  githubId           String?   @unique
  role               UserRole  @default(CLIENT)
  firstName          String
  lastName           String
  bio                String?   @db.Text
  avatar             String?
  coverImage         String?
  hourlyRate         Decimal?  @db.Decimal(10, 2)
  currency           String    @default("USD") @db.VarChar(3)
  country            String?
  city               String?
  timezone           String?
  isVerified         Boolean   @default(false)
  isActive           Boolean   @default(true)
  lastSeen           DateTime?
  profileCompleteness Int      @default(0)
  totalEarned        Decimal   @default(0) @db.Decimal(15, 2)
  totalSpent         Decimal   @default(0) @db.Decimal(15, 2)
  completionRate     Decimal   @default(0) @db.Decimal(5, 2)
  rating             Decimal?  @db.Decimal(3, 2)
  totalReviews       Int       @default(0)
  bidCredits         Int       @default(10)
  totalBidsPlaced    Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  projects                Project[]                @relation("ClientProjects")
  bids                    Bid[]                    @relation("FreelancerBids")
  contractsAsClient       Contract[]               @relation("ClientContracts")
  contractsAsFreelancer   Contract[]               @relation("FreelancerContracts")
  transactionsPaid        Transaction[]            @relation("Payer")
  transactionsReceived    Transaction[]            @relation("Payee")
  reviewsGiven            Review[]                 @relation("Reviewer")
  reviewsReceived         Review[]                 @relation("Reviewee")
  disputesInitiated       Dispute[]                @relation("DisputeInitiator")
  disputesResponded       Dispute[]                @relation("DisputeRespondent")
  disputesAssigned        Dispute[]                @relation("DisputeAdmin")
  conversations           ConversationParticipant[]
  messages                Message[]
  notifications           Notification[]
  skills                  UserSkill[]
  badges                  UserBadge[]

  @@index([email])
  @@index([role])
  @@index([isVerified])
  @@index([isActive])
  @@index([country])
  @@index([createdAt])
  @@index([totalEarned])
  @@index([completionRate])
  @@index([rating])

  @@map("users")
}

// -----------------------------------------------------------------------------
// Category
// -----------------------------------------------------------------------------

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  parentId  String?
  createdAt DateTime   @default(now())

  // Self-relation for subcategories
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  // Relations
  projects Project[]

  @@index([slug])
  @@index([parentId])

  @@map("categories")
}

// -----------------------------------------------------------------------------
// Skill
// -----------------------------------------------------------------------------

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  category  String
  createdAt DateTime    @default(now())

  // Relations
  users UserSkill[]

  @@index([category])
  @@index([name])

  @@map("skills")
}

// -----------------------------------------------------------------------------
// UserSkill (join table)
// -----------------------------------------------------------------------------

model UserSkill {
  userId  String
  skillId String
  level   SkillLevel

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@index([level])

  @@map("user_skills")
}

// -----------------------------------------------------------------------------
// Project
// -----------------------------------------------------------------------------

model Project {
  id         String            @id @default(cuid())
  clientId   String
  categoryId String?
  title      String
  description String           @db.Text
  type       ProjectType
  budgetMin  Decimal           @db.Decimal(15, 2)
  budgetMax  Decimal           @db.Decimal(15, 2)
  currency   String            @default("USD") @db.VarChar(3)
  deadline   DateTime?
  skills     String[]
  status     ProjectStatus     @default(DRAFT)
  visibility ProjectVisibility @default(PUBLIC)
  attachments Json             @default("[]")
  viewCount  Int               @default(0)
  bidCount   Int               @default(0)
  deletedAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  client        User          @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Restrict)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bids          Bid[]
  contract      Contract?
  conversations Conversation[]

  @@index([clientId])
  @@index([categoryId])
  @@index([status])
  @@index([type])
  @@index([visibility])
  @@index([budgetMin])
  @@index([budgetMax])
  @@index([deadline])
  @@index([bidCount])
  @@index([viewCount])
  @@index([createdAt])
  @@index([status, visibility])
  @@index([clientId, status])

  @@map("projects")
}

// -----------------------------------------------------------------------------
// Bid
// -----------------------------------------------------------------------------

model Bid {
  id           String    @id @default(cuid())
  projectId    String
  freelancerId String
  amount       Decimal   @db.Decimal(15, 2)
  currency     String    @db.VarChar(3)
  deliveryDays Int
  coverLetter  String    @db.Text
  attachments  Json      @default("[]")
  status       BidStatus @default(PENDING)
  isRead       Boolean   @default(false)
  skillMatchScore Decimal? @db.Decimal(5, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer User      @relation("FreelancerBids", fields: [freelancerId], references: [id], onDelete: Restrict)
  contract   Contract?

  @@unique([projectId, freelancerId])
  @@index([projectId])
  @@index([freelancerId])
  @@index([status])
  @@index([isRead])
  @@index([createdAt])
  @@index([amount])
  @@index([projectId, status])
  @@index([freelancerId, status])

  @@map("bids")
}

// -----------------------------------------------------------------------------
// Contract
// -----------------------------------------------------------------------------

model Contract {
  id           String         @id @default(cuid())
  projectId    String         @unique
  bidId        String         @unique
  clientId     String
  freelancerId String
  title        String
  description  String         @db.Text
  amount       Decimal        @db.Decimal(15, 2)
  currency     String         @db.VarChar(3)
  status       ContractStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  terms        String         @db.Text
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  bid           Bid            @relation(fields: [bidId], references: [id], onDelete: Restrict)
  client        User           @relation("ClientContracts", fields: [clientId], references: [id], onDelete: Restrict)
  freelancer    User           @relation("FreelancerContracts", fields: [freelancerId], references: [id], onDelete: Restrict)
  milestones    Milestone[]
  transactions  Transaction[]
  reviews       Review[]
  disputes      Dispute[]
  conversations Conversation[]

  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@index([clientId, status])
  @@index([freelancerId, status])

  @@map("contracts")
}

// -----------------------------------------------------------------------------
// Milestone
// -----------------------------------------------------------------------------

model Milestone {
  id                    String          @id @default(cuid())
  contractId            String
  title                 String
  description           String          @db.Text
  amount                Decimal         @db.Decimal(15, 2)
  currency              String          @db.VarChar(3)
  dueDate               DateTime?
  order                 Int
  status                MilestoneStatus @default(PENDING)
  submissionNote        String?         @db.Text
  submissionAttachments Json            @default("[]")
  reviewNote            String?         @db.Text
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Relations
  contract     Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  disputes     Dispute[]

  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@index([order])
  @@index([contractId, status])
  @@index([contractId, order])

  @@map("milestones")
}

// -----------------------------------------------------------------------------
// Transaction
// -----------------------------------------------------------------------------

model Transaction {
  id          String            @id @default(cuid())
  contractId  String?
  milestoneId String?
  payerId     String
  payeeId     String
  amount      Decimal           @db.Decimal(15, 2)
  currency    String            @db.VarChar(3)
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  externalId  String?
  gateway     String?
  metadata    Json?
  description String?
  feeAmount   Decimal           @default(0) @db.Decimal(15, 2)
  netAmount   Decimal           @db.Decimal(15, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  contract  Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  payer     User       @relation("Payer", fields: [payerId], references: [id], onDelete: Restrict)
  payee     User       @relation("Payee", fields: [payeeId], references: [id], onDelete: Restrict)

  @@index([contractId])
  @@index([milestoneId])
  @@index([payerId])
  @@index([payeeId])
  @@index([type])
  @@index([status])
  @@index([externalId])
  @@index([gateway])
  @@index([createdAt])
  @@index([payerId, type])
  @@index([payeeId, type])
  @@index([contractId, status])

  @@map("transactions")
}

// -----------------------------------------------------------------------------
// Review
// -----------------------------------------------------------------------------

model Review {
  id                   String       @id @default(cuid())
  contractId           String
  reviewerId           String
  revieweeId           String
  rating               Int
  comment              String       @db.Text
  communicationRating  Int
  qualityRating        Int
  timelinessRating     Int
  type                 ReviewType
  status               ReviewStatus @default(PENDING)
  moderationReason     String?      @db.Text
  moderatedAt          DateTime?
  moderatedBy          String?
  isPublic             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reviewer User     @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  reviewee User     @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Restrict)

  @@unique([contractId, reviewerId])
  @@index([contractId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([rating])
  @@index([type])
  @@index([status])
  @@index([isPublic])
  @@index([createdAt])
  @@index([revieweeId, isPublic])
  @@index([revieweeId, rating])
  @@index([status, createdAt])

  @@map("reviews")
}

// -----------------------------------------------------------------------------
// Dispute
// -----------------------------------------------------------------------------

model Dispute {
  id               String        @id @default(cuid())
  contractId       String
  milestoneId      String?
  initiatorId      String
  respondentId     String
  assignedAdminId  String?
  reason           DisputeReason
  description      String        @db.Text
  status           DisputeStatus @default(OPEN)
  resolution       String?       @db.Text
  adminNote        String?       @db.Text
  attachments      Json          @default("[]")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  resolvedAt       DateTime?

  // Relations
  contract      Contract   @relation(fields: [contractId], references: [id], onDelete: Restrict)
  milestone     Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  initiator     User       @relation("DisputeInitiator", fields: [initiatorId], references: [id], onDelete: Restrict)
  respondent    User       @relation("DisputeRespondent", fields: [respondentId], references: [id], onDelete: Restrict)
  assignedAdmin User?      @relation("DisputeAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([milestoneId])
  @@index([initiatorId])
  @@index([respondentId])
  @@index([assignedAdminId])
  @@index([status])
  @@index([reason])
  @@index([createdAt])
  @@index([resolvedAt])
  @@index([status, createdAt])

  @@map("disputes")
}

// -----------------------------------------------------------------------------
// Conversation
// -----------------------------------------------------------------------------

model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType @default(DIRECT)
  projectId     String?
  contractId    String?
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  project      Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contract     Contract?                 @relation(fields: [contractId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([type])
  @@index([projectId])
  @@index([contractId])
  @@index([lastMessageAt])
  @@index([createdAt])

  @@map("conversations")
}

// -----------------------------------------------------------------------------
// ConversationParticipant (join table)
// -----------------------------------------------------------------------------

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  isArchived     Boolean   @default(false)

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([isArchived])
  @@index([userId, isArchived])

  @@map("conversation_participants")
}

// -----------------------------------------------------------------------------
// Message
// -----------------------------------------------------------------------------

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String      @db.Text
  type           MessageType @default(TEXT)
  attachments    Json        @default("[]")
  isEdited       Boolean     @default(false)
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId])
  @@index([senderId])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([conversationId, createdAt])
  @@index([conversationId, deletedAt])

  @@map("messages")
}

// -----------------------------------------------------------------------------
// Badge
// -----------------------------------------------------------------------------

model Badge {
  id          String    @id @default(cuid())
  name        String    @unique
  type        BadgeType
  description String    @db.Text
  icon        String?
  criteria    Json
  createdAt   DateTime  @default(now())

  // Relations
  users UserBadge[]

  @@index([type])
  @@index([name])

  @@map("badges")
}

// -----------------------------------------------------------------------------
// UserBadge (join table)
// -----------------------------------------------------------------------------

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@index([awardedAt])

  @@map("user_badges")
}

// -----------------------------------------------------------------------------
// Notification
// -----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])

  @@map("notifications")
}
