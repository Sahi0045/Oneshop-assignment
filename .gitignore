# =============================================================================
# FREELANCER PLATFORM - .gitignore
# Turborepo + pnpm Monorepo
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/
**/.turbo/

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/
**/.cache/

# Next.js
.next/
apps/web/.next/
apps/web/out/

# Expo / React Native
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
expo-env.d.ts

# NestJS
packages/backend/dist/

# TypeScript
*.tsbuildinfo
**/*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.production
.env.production.local
**/.env
**/.env.local
**/.env.*.local

# Keep example files
!.env.example
!**/.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
lcov.info
*.lcov
jest-results.json
test-results/
playwright-report/
playwright/.cache/
.jest-cache/

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Keep schema and seed files, ignore generated client and migration locks
packages/shared/src/generated/
packages/shared/prisma/migrations/*.lock

# Keep migration files (source of truth for schema changes)
!packages/shared/prisma/migrations/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local docker volume data (if mounted in project dir)
docker/data/
docker/volumes/
.docker/

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------

# VSCode - ignore personal settings, keep recommended extensions and workspace tasks
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json.example

# JetBrains IDEs (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.nvimrc.local

# Emacs
*#
.dir-locals.el

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Package Manager Artifacts
# -----------------------------------------------------------------------------
# pnpm
.pnpm-store/

# npm
package-lock.json
# Keep pnpm-lock.yaml (source of truth)
# pnpm-lock.yaml  <-- DO NOT ignore this

# Yarn
yarn.lock
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

# Storybook
storybook-static/
**/storybook-static/

# Sentry
.sentryclirc

# Vercel
.vercel/

# Netlify
.netlify/

# AWS CDK
cdk.out/
cdk.context.json

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# Serverless Framework
.serverless/

# Bundle analyzer
bundle-analyzer-report.html
.bundle-stats.json

# Temporary files
tmp/
temp/
.temp/
.tmp/

# Debug
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# SvelteKit
.svelte-kit/

# Astro
.astro/

# Gradle (React Native)
apps/mobile/android/.gradle/
apps/mobile/android/app/build/
apps/mobile/android/build/
apps/mobile/android/local.properties
apps/mobile/.gradle/

# Xcode (React Native / iOS)
apps/mobile/ios/build/
apps/mobile/ios/Pods/
apps/mobile/ios/*.xcworkspace/xcuserdata/
apps/mobile/ios/DerivedData/
apps/mobile/ios/.xcode.env.local
apps/mobile/*.xcarchive

# Buck
apps/mobile/.buckd/
apps/mobile/buck-out/

# Flipper
apps/mobile/ios/Flipper/

# CocoaPods
apps/mobile/ios/Pods/

# Fastlane (mobile CI/CD)
apps/mobile/fastlane/report.xml
apps/mobile/fastlane/Preview.html
apps/mobile/fastlane/screenshots/
apps/mobile/fastlane/test_output/

# Generated source maps
*.map
!**/*.map.example

# Certificates and secrets (extra safety net)
*.pem
*.crt
*.cer
*.der
*.p7b
*.p7r
*.csr
*.srl
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
