# =============================================================================
# FREELANCER PLATFORM - ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://freelancer:password@localhost:5432/freelancer_db
DATABASE_TEST_URL=postgresql://freelancer:password@localhost:5432/freelancer_db_test
DATABASE_MAX_CONNECTIONS=10
DATABASE_SSL=false

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB=0

# =============================================================================
# ELASTICSEARCH
# =============================================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=freelancer

# =============================================================================
# KAFKA (Message Broker)
# =============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=freelancer-platform
KAFKA_CLIENT_ID=freelancer-api
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=freelancer-platform-uploads
AWS_S3_ENDPOINT=
AWS_CLOUDFRONT_URL=

# =============================================================================
# STRIPE (Payments)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_VERSION=2023-10-16

# =============================================================================
# SENDGRID (Transactional Email)
# =============================================================================
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@freelancerplatform.com
SENDGRID_FROM_NAME=Freelancer Platform
SENDGRID_REPLY_TO=support@freelancerplatform.com

# =============================================================================
# MAILHOG (Local Dev SMTP — not for production)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# =============================================================================
# GOOGLE OAUTH 2.0
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# =============================================================================
# GITHUB OAUTH
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# =============================================================================
# LINKEDIN OAUTH
# =============================================================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/auth/linkedin/callback

# =============================================================================
# FIREBASE CLOUD MESSAGING (Push Notifications)
# =============================================================================
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
MOBILE_DEEP_LINK_SCHEME=freelancer

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# =============================================================================
# PLATFORM CONFIGURATION
# =============================================================================
PLATFORM_FEE_PERCENTAGE=10
PLATFORM_MIN_WITHDRAWAL_AMOUNT=50
PLATFORM_CURRENCY=USD
PLATFORM_MAX_FILE_UPLOAD_SIZE_MB=25
PLATFORM_SUPPORTED_FILE_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,gif,zip

# =============================================================================
# NEXT.JS WEB APP (prefix with NEXT_PUBLIC_ for browser exposure)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# =============================================================================
# REACT NATIVE / EXPO (MOBILE APP)
# =============================================================================
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
DATADOG_API_KEY=
DATADOG_APP_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_ESCROW_ENABLED=true
FEATURE_VIDEO_CALLS_ENABLED=false
FEATURE_AI_MATCHING_ENABLED=false
FEATURE_CRYPTO_PAYMENTS_ENABLED=false

# =============================================================================
# DOCKER / DEPLOYMENT
# =============================================================================
COMPOSE_PROJECT_NAME=freelancer-platform
POSTGRES_USER=freelancer
POSTGRES_PASSWORD=password
POSTGRES_DB=freelancer_db
